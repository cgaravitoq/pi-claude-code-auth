{
	"name": "@cgaravitoq/pi-claude-code-auth",
	"version": "2.2.2",
	"description": "pi extension: authenticate the Anthropic provider via your existing Claude Code OAuth session",
	"type": "module",
	"license": "MIT",
	"author": "cgaravitoq",
	"homepage": "https://github.com/cgaravitoq/pi-claude-code-auth",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cgaravitoq/pi-claude-code-auth.git"
	},
	"bugs": {
		"url": "https://github.com/cgaravitoq/pi-claude-code-auth/issues"
	},
	"keywords": [
		"pi-package",
		"pi",
		"claude",
		"claude-code",
		"anthropic",
		"oauth",
		"coding-agent"
	],
	"pi": {
		"extensions": ["./src/index.ts"]
	},
	"files": [
		"src/**/*.ts",
		"!src/**/*.test.ts",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"build": "bun build src/index.ts --target=node --format=esm --outfile=dist/index.js --external @earendil-works/pi-ai --external @earendil-works/pi-coding-agent --external @cgaravitoq/claude-code-core",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run typecheck"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.40.0",
		"@cgaravitoq/claude-code-core": "^0.1.0"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*"
	},
	"devDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@types/bun": "^1.3.14",
		"@types/node": "^22.0.0",
		"typescript": "^5.5.0"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
